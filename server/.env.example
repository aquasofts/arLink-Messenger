# NearLink Server 部署变量
# 复制为 .env 后修改：cp .env.example .env

# ---- 必填 ----

# 你的域名（已经把 A/AAAA 记录指向本机）。Caddy 会自动签发 Let's Encrypt 证书。
# 本地体验/内网部署可填 :80（Caddy 会跑 HTTP，无 TLS）。
NEARLINK_DOMAIN=nearlink.example.com

# Caddy 自动证书要给 LE 留一个邮箱（仅用于到期提醒）。
# 内网部署（NEARLINK_DOMAIN=:80）时本字段被忽略。
NEARLINK_ACME_EMAIL=admin@example.com

# Postgres 密码：留空时脚本自动生成 32 字节随机串并写回 .env
POSTGRES_PASSWORD=

# ---- 可选 ----

# 存储驱动: postgres | sqlite
NEARLINK_STORAGE_DRIVER=postgres

# 服务器进程内部监听端口（容器内）。一般不用改。
NEARLINK_HTTP_ADDR=:8080

# 日志：debug | info | warn | error
NEARLINK_LOG_LEVEL=info

# 离线消息保留时长（go duration）。14 天 = 336h。
NEARLINK_OFFLINE_TTL=336h

# 单条密文上限（字节）。附件走文件 API（roadmap），文本默认 64KiB。
NEARLINK_MAX_MSG_BYTES=65536
